generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum Currency {
  MXN
  USD
}

enum DebtStatus {
  ACTIVE
  PAID
  PAUSED
  DEFAULTED
}

enum CategoryScope {
  INCOME
  EXPENSE
  INVESTMENT
  DEBT
}

enum InvestmentType {
  FIXED_INCOME
  STOCKS
  CRYPTO
  SAVINGS
  OTHER
}

model User {
  id                  String                    @id @default(cuid())
  name                String
  email               String                    @unique
  passwordHash        String
  role                Role                      @default(USER)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  months              Month[]
  incomes             Income[]
  expenses            Expense[]
  expenseTemplates    ExpenseTemplate[]
  investmentAccounts  InvestmentAccount[]
  debts               Debt[]
  recommendations     Recommendation[]
}

model Month {
  id              String          @id @default(cuid())
  userId          String
  label           String
  year            Int
  month           Int
  startsAt        DateTime
  endsAt          DateTime
  createdAt       DateTime        @default(now())
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes         Income[]
  expenses        Expense[]
  investmentSnapshots InvestmentMonthlySnapshot[]
  recommendations Recommendation[]

  @@unique([userId, year, month])
  @@index([userId, startsAt])
}

model Category {
  id          String        @id @default(cuid())
  name        String
  scope       CategoryScope
  parentId    String?
  isGlobal    Boolean       @default(false)
  createdAt   DateTime      @default(now())
  parent      Category?     @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[]    @relation("CategoryHierarchy")

  @@unique([name, scope, parentId])
}

model Income {
  id          String    @id @default(cuid())
  userId      String
  monthId     String
  name        String
  category    String
  currency    Currency
  amount      Decimal   @db.Decimal(14, 2)
  date        DateTime
  recurring   Boolean   @default(false)
  comments    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  month       Month     @relation(fields: [monthId], references: [id], onDelete: Cascade)

  @@index([userId, monthId, currency])
}

model Expense {
  id          String        @id @default(cuid())
  userId      String
  monthId     String
  templateId  String?
  name        String
  currency    Currency
  amount      Decimal       @db.Decimal(14, 2)
  expenseDate DateTime
  recurring   Boolean       @default(false)
  comments    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  month       Month         @relation(fields: [monthId], references: [id], onDelete: Cascade)
  template    ExpenseTemplate? @relation(fields: [templateId], references: [id])

  @@index([userId, monthId, currency])
}

model ExpenseTemplate {
  id             String    @id @default(cuid())
  userId         String
  name           String
  currency       Currency
  amount         Decimal   @db.Decimal(14, 2)
  dueDay         Int
  active         Boolean   @default(true)
  comments       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses       Expense[]

  @@index([userId, active, currency])
}

model InvestmentAccount {
  id            String                      @id @default(cuid())
  userId        String
  name          String
  institution   String
  currency      Currency
  type          InvestmentType
  initialAmount Decimal                     @db.Decimal(14, 2)
  startDate     DateTime
  isActive      Boolean                     @default(true)
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt
  user          User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots     InvestmentMonthlySnapshot[]

  @@index([userId, currency, isActive])
  @@index([userId, type])
}

model InvestmentMonthlySnapshot {
  id                              String            @id @default(cuid())
  investmentAccountId             String
  financialMonthId                String
  amountAtStartOfMonth            Decimal           @db.Decimal(14, 2)
  contributionAmount              Decimal           @db.Decimal(14, 2)
  withdrawalAmount                Decimal           @db.Decimal(14, 2)
  amountAtEndOfMonth              Decimal           @db.Decimal(14, 2)
  profitGeneratedThisMonth        Decimal           @db.Decimal(14, 2)
  accumulatedProfitUntilThisMonth Decimal           @db.Decimal(14, 2)
  performancePercentage           Decimal           @db.Decimal(8, 4)
  notes                           String?
  createdAt                       DateTime          @default(now())
  updatedAt                       DateTime          @updatedAt
  investmentAccount               InvestmentAccount @relation(fields: [investmentAccountId], references: [id], onDelete: Cascade)
  financialMonth                  Month             @relation(fields: [financialMonthId], references: [id], onDelete: Cascade)

  @@unique([investmentAccountId, financialMonthId])
  @@index([financialMonthId])
  @@index([investmentAccountId, createdAt])
}

model Debt {
  id             String     @id @default(cuid())
  userId         String
  name           String
  type           String
  currency       Currency
  totalBalance   Decimal    @db.Decimal(14, 2)
  monthlyPayment Decimal    @db.Decimal(14, 2)
  interestRate   Decimal    @db.Decimal(8, 4)
  dueDate        DateTime
  status         DebtStatus @default(ACTIVE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, currency, status])
}

model Recommendation {
  id        String   @id @default(cuid())
  userId    String
  monthId   String
  currency  Currency?
  severity  String
  title     String
  message   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month     Month    @relation(fields: [monthId], references: [id], onDelete: Cascade)

  @@index([userId, monthId, severity])
}
